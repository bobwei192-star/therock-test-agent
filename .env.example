# Test Case Agent runtime
TEST_CASE_AGENT_MODEL_PROVIDER=amd
TEST_CASE_AGENT_THREAD_ID=test-case-agent-debug
TEST_CASE_AGENT_TRACE_DIR=traces/test-case-agent-debug

# Shared LLM options
LLM_TEMPERATURE=0.2
LLM_REQUEST_TIMEOUT=120
LLM_MAX_RETRIES=2

# AMD OpenAI-compatible provider
AMD_LLM_BASE_URL=https://llm-api.amd.com/OnPrem
AMD_LLM_MODEL=GPT55
AMD_LLM_API_KEY=dummy
AMD_LLM_SUBSCRIPTION_KEY=
AMD_LLM_USER=

# DeepSeek provider
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=

# OpenAI provider
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=

# Generic OpenAI-compatible provider
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# Langfuse local/self-hosted
# Langfuse 部署后打开 http://localhost:3000 点击左下角 Settings -> API Keys 获取密钥
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# LangGraph local dev
LANGGRAPH_API_URL=http://127.0.0.1:2024