#
# TheRock test agent local environment.
#
# Do NOT put sudo/root passwords in this file.
# The agent never stores sudo passwords. If a test machine needs sudo, use
# either sudo's timestamp cache or the session-scoped askpass agent.
#

# none:
#   Default. The runner does not expect sudo.
# cache:
#   User must run `sudo -v` before `/therock-run`.
#   The runner checks `sudo -n true` and fails fast if the cache expired.
# askpass:
#   Run `./scripts/therock-sudo-agent start` once before OpenCode.
#   Password stays in that process memory and is served through SUDO_ASKPASS.
THEROCK_SUDO_POLICY=cache

# Non-sensitive askpass paths. `install.sh --setup-sudo-agent` can fill these.
THEROCK_SUDO_ASKPASS=
THEROCK_SUDO_AGENT_SOCKET=

# Optional paths used by commands or local notes. The runner also accepts CLI args.
THEROCK_REPO=
THEROCK_DEFAULT_ARTIFACTS=
THEROCK_GPU=gfx1151

# auto:
#   Prepare host dependencies before tests: apt packages, TheRock .venv,
#   requirements.txt, and boto3 import check.
# off:
#   Skip host bootstrap.
THEROCK_BOOTSTRAP_ENV=auto

# WSL2 ROCm normally requires /dev/dxg. Keep this unset for real GPU runs.
# Set to 1 only for mock/local self-tests on machines without WSL GPU passthrough.
THEROCK_ALLOW_MISSING_WSL_DXG=

# Optional WSL2 ROCDXG override. Set this only when librocdxg.so lives outside
# the selected artifacts and standard ROCm locations.
THEROCK_ROCDXG_SEARCH_PATHS=

# Optional OpenCode/headless behavior hint. This is not a password.
THEROCK_HEADLESS_FORMAT=json
